# GitHub repo secrets & variables for CI/CD.
# Copy to .env.secrets, fill in values, run: ./custom-tools/setup-repo-secrets.sh
#
# To sync to a different repo:
#   GITHUB_REPO=PopupMaker/other-plugin ./custom-tools/setup-repo-secrets.sh

# --- Secrets (encrypted, not visible in logs) ---

# WordPress.org SVN deployment.
SVN_USERNAME=
SVN_PASSWORD=

# Slack webhook URLs.
SLACK_WEBHOOK=
SLACK_WEBHOOK_DEV=
SLACK_WEBHOOK_SUPPORT=

# EDD store sync auth token.
EDD_WEBHOOK_TOKEN=

# Google Drive service account JSON (paste the full JSON, or path to file).
GOOGLE_DRIVE_CREDENTIALS=

# --- Variables (visible in logs, non-sensitive) ---

# EDD product ID on code-atlantic.com (set to 0 or empty to skip).
EDD_PRODUCT_ID=
EDD_WEBHOOK_URL=https://code-atlantic.com/wp-json/edd-release-manager/v1/webhook

# Google Drive folder IDs for release backups.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_BETA_FOLDER_ID=
